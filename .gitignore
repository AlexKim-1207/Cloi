# 환경 변수 (API 키 보호 - 절대 커밋하지 않음)
.env
.env.local
.env.*.local

# 의존성
node_modules/
server/node_modules/

# 빌드 결과물
dist/
server/dist/

# 로그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# 인증서 (mTLS - 절대 커밋하지 않음)
*.pem
*.key
*.crt
*.p12
certs/

# Security: token-containing scripts
scripts/setup_token_and_run.bat
scripts/setup_token*
scripts/setup_token_and_run.ps1

# Python
__pycache__/
*.pyc
*.pyo
.venv/
fashion-search/.venv/

# ML artifacts (local-only, big binaries)
fashion-search/weights/
fashion-search/artifacts/
fashion-search/src/data/catalog/*.jpg
fashion-search/src/data/catalog/images/
fashion-search/src/data/catalog/meta.json

# Wrangler/build cache
.wrangler/
server/.wrangler/
.bkit/
dist-test/

# Backup/log dumps
.env.production
tail-output.txt
server/deploy_log.txt
