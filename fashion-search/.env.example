# Gemini
GOOGLE_API_KEY=your_gemini_api_key

# 네이버 검색 API (https://developers.naver.com/apps/#/register)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Models (weights 경로 — Phase 2 FAISS 파이프라인용)
GDINO_CHECKPOINT=weights/groundingdino_swint_ogc.pth
GDINO_CONFIG=weights/GroundingDINO_SwinT_OGC.py
SAM2_CHECKPOINT=weights/sam2_hiera_large.pt
SAM2_MODEL_CFG=sam2_hiera_l.yaml

# Paths
CATALOG_DIR=src/data/catalog
ARTIFACTS_DIR=artifacts
DB_PATH=artifacts/search_logs.db

# Runtime (Phase 2 FAISS)
FAISS_NPROBE=10
GEMINI_CONFIDENCE_THRESHOLD=0.70
CACHE_TTL_HOURS=24

# CLIP
CLIP_MODEL=ViT-L-14
CLIP_PRETRAINED=laion2b_s32b_b82k
CLIP_MIN_SIMILARITY=0.20

# v2 검색 파라미터
SEARCH_RESULTS_PER_ITEM=50
TOP_K_PER_CATEGORY=5
