# Gemini
GOOGLE_API_KEY=your_key_here

# Models (weights 경로)
GDINO_CHECKPOINT=weights/groundingdino_swint_ogc.pth
GDINO_CONFIG=weights/GroundingDINO_SwinT_OGC.py
SAM2_CHECKPOINT=weights/sam2_hiera_large.pt
SAM2_MODEL_CFG=sam2_hiera_l.yaml

# Paths
CATALOG_DIR=src/data/catalog
ARTIFACTS_DIR=artifacts

# Runtime
FAISS_NPROBE=10
GEMINI_CONFIDENCE_THRESHOLD=0.70
CACHE_TTL_HOURS=24
