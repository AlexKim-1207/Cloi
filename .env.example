# ================================
# 웨어고(Whereго) 환경 변수 템플릿
# 이 파일을 복사해 .env로 만들고 실제 값을 입력하세요
# .env 파일은 절대 커밋하지 마세요 (.gitignore에 포함됨)
# ================================

# Gemini Flash API (Google AI Studio에서 발급)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 네이버 쇼핑 API (네이버 개발자센터에서 발급)
# https://developers.naver.com/apps
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 서버 설정
PORT=3001
NODE_ENV=development

# 프론트엔드 - 백엔드 API 주소 (Vite 환경변수는 VITE_ 접두사 필요)
VITE_API_BASE_URL=http://localhost:3001
